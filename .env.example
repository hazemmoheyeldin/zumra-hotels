# Google Places API Key (optional - enables live hotel data lookup)
# Get a key at: https://console.cloud.google.com/apis/credentials
# Enable "Places API" in your Google Cloud project
VITE_GOOGLE_PLACES_API_KEY=

# Geoapify API Key (optional - enables hotel geocoding & location lookup)
# Get a free key at: https://www.geoapify.com/ (3000 credits/day free)
VITE_GEOAPIFY_API_KEY=

# Firebase Config (required for cloud sync)
# Get from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# EmailJS Config (required for invitation emails)
# Get from https://dashboard.emailjs.com
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ExchangeRate-API Key (server-side only - no VITE_ prefix!)
# Get from https://www.exchangerate-api.com/ (free tier: 1500 requests/month)
# Used by /api/rates.ts serverless function for live currency conversion
EXCHANGE_RATE_API_KEY=

# Upstash Redis (server-side only - no VITE_ prefix!)
# Auto-configured when Upstash is connected to Vercel project
# For local dev: vercel env pull .env.local
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Firebase Admin SDK Service Account (server-side only - no VITE_ prefix!)
# Generate from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Paste the entire JSON string (escaped) as the value
FIREBASE_ADMIN_SERVICE_ACCOUNT=

# Cache Invalidation Token (server-side only - no VITE_ prefix!)
# A shared secret used by the frontend to authorize cache invalidation requests
# Generate any random 32+ char string (e.g., openssl rand -hex 32)
CACHE_INVALIDATE_TOKEN=
