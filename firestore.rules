rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: public read for login username→email lookup
    // User docs contain only username, name, role, email (no secrets)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // All other collections: require authentication
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
