rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: public read for login username→email lookup
    // Write: any authenticated user (admin manages all users via doAddUser)
    // The login flow NO LONGER writes to this collection (fixed write-loop bug)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // All other collections: require authentication AND active status
    // Deactivated users (isActive == false) are blocked from ALL reads/writes
    match /{document=**} {
      allow read, write: if request.auth != null
        && (
          !exists(/databases/$(database)/documents/users/$(request.auth.uid))
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive != false
        );
    }
  }
}
